{
  "name": "@farming-labs/next",
  "version": "0.2.40",
  "description": "Next.js adapter for @farming-labs/docs — MDX config wrapper",
  "keywords": [
    "docs",
    "documentation",
    "mdx",
    "next"
  ],
  "license": "MIT",
  "author": "Farming Labs",
  "files": [
    "dist",
    "styles"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./api-reference": {
      "types": "./dist/api-reference.d.mts",
      "import": "./dist/api-reference.mjs",
      "default": "./dist/api-reference.mjs"
    },
    "./api-reference.css": "./styles/api-reference.css",
    "./api": {
      "types": "./dist/api.d.mts",
      "import": "./dist/api.mjs",
      "default": "./dist/api.mjs"
    },
    "./changelog": {
      "types": "./dist/changelog.d.mts",
      "import": "./dist/changelog.mjs",
      "default": "./dist/changelog.mjs"
    },
    "./client-callbacks": {
      "types": "./dist/client-callbacks.d.mts",
      "import": "./dist/client-callbacks.mjs",
      "default": "./dist/client-callbacks.mjs"
    },
    "./layout": {
      "types": "./dist/layout.d.mts",
      "import": "./dist/layout.mjs",
      "default": "./dist/layout.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs",
      "default": "./dist/config.mjs"
    },
    "./mdx-plugins/remark-heading": {
      "types": "./dist/mdx-plugins/remark-heading.d.mts",
      "import": "./dist/mdx-plugins/remark-heading.mjs",
      "default": "./dist/mdx-plugins/remark-heading.mjs"
    },
    "./mdx-plugins/remark-code-group": {
      "types": "./dist/mdx-plugins/remark-code-group.d.mts",
      "import": "./dist/mdx-plugins/remark-code-group.mjs",
      "default": "./dist/mdx-plugins/remark-code-group.mjs"
    },
    "./mdx-plugins/rehype-toc": {
      "types": "./dist/mdx-plugins/rehype-toc.d.mts",
      "import": "./dist/mdx-plugins/rehype-toc.mjs",
      "default": "./dist/mdx-plugins/rehype-toc.mjs"
    },
    "./mdx-plugins/rehype-code": {
      "types": "./dist/mdx-plugins/rehype-code.d.mts",
      "import": "./dist/mdx-plugins/rehype-code.mjs",
      "default": "./dist/mdx-plugins/rehype-code.mjs"
    },
    "./mdx-plugins/remark-og": {
      "types": "./dist/mdx-plugins/remark-og.d.mts",
      "import": "./dist/mdx-plugins/remark-og.mjs",
      "default": "./dist/mdx-plugins/remark-og.mjs"
    },
    "./mdx-plugins/remark-markdown-alternate": {
      "types": "./dist/mdx-plugins/remark-markdown-alternate.d.mts",
      "import": "./dist/mdx-plugins/remark-markdown-alternate.mjs",
      "default": "./dist/mdx-plugins/remark-markdown-alternate.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.1.6",
    "@scalar/nextjs-api-reference": "0.10.3",
    "fumadocs-openapi": "10.7.0",
    "fumadocs-core": "16.7.16",
    "fumadocs-ui": "16.7.16",
    "gray-matter": "^4.0.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@farming-labs/docs": "workspace:*",
    "@farming-labs/theme": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@farming-labs/docs": ">=0.0.1",
    "@farming-labs/theme": ">=0.0.1",
    "next": ">=16.0.0",
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0"
  }
}
