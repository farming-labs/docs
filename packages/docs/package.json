{
  "name": "@farming-labs/docs",
  "version": "0.1.46",
  "description": "Modern, flexible MDX-based docs framework — core types, config, and CLI",
  "keywords": [
    "docs",
    "documentation",
    "mdx"
  ],
  "license": "MIT",
  "author": "Farming Labs",
  "bin": {
    "docs": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs",
      "default": "./dist/server.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.mts",
      "import": "./dist/mcp.mjs",
      "default": "./dist/mcp.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@scalar/core": "^0.4.3",
    "gray-matter": "^4.0.3",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
