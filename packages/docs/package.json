{
  "name": "@farming-labs/docs",
  "version": "0.2.68",
  "description": "Modern, flexible MDX-based docs framework — core types, config, and CLI",
  "keywords": [
    "docs",
    "documentation",
    "mdx"
  ],
  "license": "MIT",
  "author": "Farming Labs",
  "bin": {
    "docs": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs",
      "default": "./dist/server.mjs"
    },
    "./agent-skills-bundle": {
      "types": "./dist/agent-skills-bundle.d.mts",
      "import": "./dist/agent-skills-bundle.mjs",
      "default": "./dist/agent-skills-bundle.mjs"
    },
    "./vite": {
      "types": "./dist/agent-skills-vite.d.mts",
      "import": "./dist/agent-skills-vite.mjs",
      "default": "./dist/agent-skills-vite.mjs"
    },
    "./cloud/server": {
      "types": "./dist/docs-cloud-server.d.mts",
      "import": "./dist/docs-cloud-server.mjs",
      "default": "./dist/docs-cloud-server.mjs"
    },
    "./client/react": {
      "types": "./dist/client/react.d.mts",
      "import": "./dist/client/react.mjs",
      "default": "./dist/client/react.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.mts",
      "import": "./dist/mcp.mjs",
      "default": "./dist/mcp.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@mdx-js/mdx": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@scalar/core": "^0.4.3",
    "@vercel/sandbox": "^2.0.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.7.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
