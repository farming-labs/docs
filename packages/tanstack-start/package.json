{
  "name": "@farming-labs/tanstack-start",
  "version": "0.0.33",
  "description": "TanStack Start adapter for @farming-labs/docs — content loading, search, and AI utilities",
  "keywords": [
    "docs",
    "documentation",
    "tanstack",
    "tanstack-start"
  ],
  "license": "MIT",
  "author": "Farming Labs",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "import": "./dist/content.js",
      "default": "./dist/content.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "fumadocs-core": "^16.6.1",
    "gray-matter": "^4.0.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0"
  },
  "devDependencies": {
    "@farming-labs/docs": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@farming-labs/docs": "*"
  }
}
