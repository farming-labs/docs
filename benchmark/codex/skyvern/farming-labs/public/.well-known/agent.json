{
  "version": "1",
  "name": "Skyvern Docs Agent Spec",
  "subject": "skyvern",
  "capabilities": {
    "markdownRoutes": true,
    "acceptTextMarkdown": true,
    "agentBlocks": true,
    "agentMdOverrides": true,
    "llms": true,
    "mcp": true,
    "agentFeedback": true,
    "wellKnownAgentJson": true
  },
  "recommendedEntry": "/docs.md",
  "recommendedTaskRunbookPattern": "/docs/agent-runbooks/task-{id}.md",
  "navigationPolicy": {
    "mode": "agent-first",
    "firstFetch": "/docs.md",
    "secondFetch": "/docs/agent-runbooks/task-{id}.md",
    "sourcePages": "Fetch canonical source pages only if the task runbook is missing an API detail or acceptance fails."
  },
  "api": {
    "docs": "/api/docs",
    "agentSpec": "/api/docs/agent/spec",
    "wellKnown": "/.well-known/agent.json",
    "activeTaskPattern": "/api/docs/agent/task/{id}"
  },
  "tasks": [
    {
      "id": 1,
      "slug": "gusto-paystub-webhook",
      "title": "Gusto pay stub download with webhook verification",
      "prompt": "Write a Python script that runs nightly via cron: log into Gusto (TOTP 2FA credential stored in Skyvern) using page.agent.login, call page.agent.download_files for the latest pay stub PDF for employee ID 4471, then POST it to https://api.ourco.com/payroll/ingest. Verify the Skyvern webhook HMAC on your receiver.",
      "canonicalPages": [
        "/docs/credentials/store-credentials.md",
        "/docs/credentials/handle-2fa.md",
        "/docs/credentials/troubleshooting-login.md",
        "/docs/going-to-production/webhooks.md",
        "/docs/sdk-reference/complete-reference.md",
        "/docs/sdk-reference/credentials.md",
        "/docs/sdk-reference/helpers.md",
        "/docs/multi-step-automations/file-operations.md"
      ],
      "requiredTokens": [
        "page.agent.login",
        "page.agent.download_files",
        "employee_id = \"4471\"",
        "https://api.ourco.com/payroll/ingest",
        "hmac",
        "cron",
        "gusto"
      ],
      "acceptanceCommand": "SKYVERN_TASK_ID=1 node scripts/acceptance.mjs",
      "outputFiles": [
        "solutions/task-1.py",
        "solutions/task-1.md"
      ]
    },
