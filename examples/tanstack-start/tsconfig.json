{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@farming-labs/docs": ["../../packages/docs/src/index.ts"],
      "@farming-labs/docs/*": ["../../packages/docs/src/*"],
      "@farming-labs/tanstack-start": [
        "../../packages/tanstack-start/src/index.ts"
      ],
      "@farming-labs/tanstack-start/*": [
        "../../packages/tanstack-start/src/*",
        "../../packages/tanstack-start/src/*/index.ts"
      ],
      "@farming-labs/theme": ["../../packages/fumadocs/src/index.ts"],
      "@farming-labs/theme/*": [
        "../../packages/fumadocs/src/*",
        "../../packages/fumadocs/src/*/index.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "docs.config.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
