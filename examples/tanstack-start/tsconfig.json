{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@farming-labs/theme": ["../../packages/fumadocs/src/index.ts"],
      "@farming-labs/theme/*": [
        "../../packages/fumadocs/src/*",
        "../../packages/fumadocs/src/*/index.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "docs.config.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
