---
const {
  color = "#ffffff",
  flakeSize = 0.003,
  minFlakeSize = 1.25,
  pixelResolution = 210,
  speed = 0.2,
  depthFade = 8,
  farPlane = 20,
  brightness = 1,
  gamma = 0.4545,
  density = 0.3,
  variant = "square",
  direction = 125,
} = Astro.props;

const options = JSON.stringify({
  color,
  flakeSize,
  minFlakeSize,
  pixelResolution,
  speed,
  depthFade,
  farPlane,
  brightness,
  gamma,
  density,
  variant,
  direction,
});
---

<div class="pixel-snow" data-pixel-snow-options={options}></div>

<script>
  import { mountPixelSnow } from "../../../shared/pixel-snow";

  const element = document.currentScript?.previousElementSibling;
  const raw = element?.getAttribute("data-pixel-snow-options") ?? "{}";

  if (element instanceof HTMLElement) {
    mountPixelSnow(element, JSON.parse(raw));
  }
</script>

<style>
  .pixel-snow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>
