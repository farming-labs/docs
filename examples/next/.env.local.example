DOCS_SEARCH_PROVIDER=typesense
TYPESENSE_URL=http://127.0.0.1:8108
TYPESENSE_COLLECTION=docs
TYPESENSE_API_KEY=replace-with-your-typesense-key

# Optional: use separate search/admin keys instead of TYPESENSE_API_KEY
# TYPESENSE_SEARCH_API_KEY=
# TYPESENSE_ADMIN_API_KEY=

# Optional: enable hybrid search with local or remote Ollama embeddings
# TYPESENSE_MODE=hybrid
# TYPESENSE_OLLAMA_MODEL=embeddinggemma
# TYPESENSE_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Or switch the example to Algolia instead.
# DOCS_SEARCH_PROVIDER=algolia
# ALGOLIA_APP_ID=replace-with-your-algolia-app-id
# ALGOLIA_INDEX_NAME=docs
# ALGOLIA_SEARCH_API_KEY=replace-with-your-algolia-search-key
#
# Optional: add an admin key if you want the example or `search sync`
# to create/update the Algolia index automatically.
# ALGOLIA_ADMIN_API_KEY=replace-with-your-algolia-admin-key
