{
  "$schema": "https://docs.farming-labs.dev/schema/docs.json",
  "version": 1,
  "docs": {
    "mode": "frameworkless",
    "runtime": "nextjs",
    "root": ".docs/site"
  },
  "content": {
    "docsRoot": "docs",
    "apiReferenceRoot": "api-reference",
    "openapi": [
      {
        "name": "Remote API",
        "path": "https://petstore3.swagger.io/api/v3/openapi.json",
        "route": "/api-reference"
      }
    ]
  },
  "site": {
    "name": "Frameworkless Example",
    "titleTemplate": "%s | Frameworkless Example",
    "description": "A local frameworkless docs project powered by @farming-labs/docs."
  },
  "theme": {
    "preset": "colorful"
  },
  "cloud": {
    "apiKey": {
      "env": "DOCS_CLOUD_API_KEY"
    },
    "deploy": {
      "enabled": false
    },
    "publish": {
      "mode": "draft-pr",
      "baseBranch": "main"
    },
    "analytics": {
      "enabled": true,
      "console": "info",
      "includeInputs": false
    }
  }
}
