{
  "$schema": "https://docs.farming-labs.dev/schema/cloud.json",
  "version": 1,
  "docs": {
    "framework": "managed",
    "root": ".docs-cloud/site"
  },
  "content": {
    "docsRoot": "docs",
    "openapi": [
      {
        "name": "Remote API",
        "path": "http://127.0.0.1:4678/openapi.json",
        "route": "/api-reference"
      }
    ]
  },
  "site": {
    "name": "Remote OpenAPI Smoke Test",
    "titleTemplate": "%s | Remote OpenAPI Smoke Test"
  },
  "theme": {
    "preset": "colorful"
  }
}