            },
            "wellKnownRoute": {
              "$ref": "#/$defs/route"
            },
            "api": {
              "$ref": "#/$defs/route"
            },
            "defaultRoute": {
              "$ref": "#/$defs/route"
            },
            "defaultDocsRoute": {
