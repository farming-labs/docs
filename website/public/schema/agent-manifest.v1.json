      "required": [
        "docs",
        "config",
        "diagnostics",
        "agentSpec",
        "agentSpecDefault",
        "agentSpecFallback",
        "agentSpecWellKnown",
        "agentSpecWellKnownJson",
        "agentSpecQuery",
        "agents",
        "agentSkillsIndex",
        "legacySkillsIndex",
        "openapi"
