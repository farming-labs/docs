# Optional: Canonical base URL for the site (used for absolute OG image URLs in production).
# Set this when using a custom domain so social previews use your domain, not *.vercel.app.
# NEXT_PUBLIC_BASE_URL=https://docs.example.com

# For AI chat (see docs.config.ts)
# OPENAI_API_KEY=sk-...

# PostgreSQL connection for Showcase (submit & list docs built with @farming-labs/docs)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

