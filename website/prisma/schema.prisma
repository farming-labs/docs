generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApprovalStatus {
  IDLE    
  APPROVED
  REJECTED
}

enum FeedbackSentiment {
  POSITIVE
  NEGATIVE
}

model ShowcaseEntry {
  id             String         @id @default(cuid())
  name           String
  url            String
  description    String?
  screenshot     String?
  approvalStatus ApprovalStatus @default(IDLE)
  createdAt      DateTime       @default(now())
}

model DocsFeedback {
  id          String            @id @default(cuid())
  value       FeedbackSentiment
  comment     String?
  url         String
  pathname    String
  entry       String
  slug        String?
  title       String?
  description String?
  locale      String?
  userAgent   String?
  referer     String?
  createdAt   DateTime          @default(now())

  @@index([createdAt])
  @@index([pathname])
  @@index([slug])
}
