generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApprovalStatus {
  IDLE    
  APPROVED
  REJECTED
}

model ShowcaseEntry {
  id             String         @id @default(cuid())
  name           String
  url            String
  description    String?
  screenshot     String?
  approvalStatus ApprovalStatus @default(IDLE)
  createdAt      DateTime       @default(now())
}
